#!/bin/bash
# Pre-commit hook: Auto-formats staged C# files before committing
# Only runs dotnet format when .cs files are staged (instant skip otherwise)
#
# Install with: ./scripts/setup-hooks.sh
# Or: make setup-hooks

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get staged .cs files (Added, Copied, Modified only)
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')

# No .cs files staged — nothing to do
if [ -z "$STAGED_CS_FILES" ]; then
    exit 0
fi

FILE_COUNT=$(echo "$STAGED_CS_FILES" | wc -l | tr -d ' ')
echo -e "${YELLOW}[pre-commit]${NC} Checking formatting of ${FILE_COUNT} C# file(s)..."

# Build --include arguments for dotnet format
INCLUDE_ARGS=""
for file in $STAGED_CS_FILES; do
    INCLUDE_ARGS="$INCLUDE_ARGS --include $file"
done

# Check if files are already formatted
if dotnet format --verify-no-changes --no-restore --verbosity quiet $INCLUDE_ARGS 2>/dev/null; then
    echo -e "${GREEN}[pre-commit] ✓ Formatting OK${NC}"
    exit 0
fi

# Files need formatting — auto-fix and re-stage
echo -e "${YELLOW}[pre-commit]${NC} Auto-formatting..."
dotnet format --no-restore --verbosity quiet $INCLUDE_ARGS 2>/dev/null

# Re-stage the formatted files
for file in $STAGED_CS_FILES; do
    if [ -f "$file" ]; then
        git add "$file"
    fi
done

echo -e "${GREEN}[pre-commit] ✓ Formatted and re-staged${NC}"
exit 0
