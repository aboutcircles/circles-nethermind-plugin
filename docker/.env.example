# Docker Compose Environment Configuration
# Copy this file to .env in the docker/ directory
# cp docker/.env.example docker/.env

# PostgreSQL Database Configuration
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres

# User/Group IDs for file permissions
# Set these to your user's UID/GID to avoid permission issues with mounted volumes
MY_UID=1000
MY_GID=1000

# Profile Service Configuration
# Path where the profile service stores its database
DATABASE_PATH=/data/profiles.db

# Reverse proxy domain
DOMAIN=your-domain.com
SERVER_IP=your.server.ip.address

CIRCLES_PLUGIN_DISABLED=false # Set to true to disable the Circles Nethermind plugin when running a reindex job

# =============================================================================
# NETHERMIND NETWORK CONFIGURATION
# =============================================================================
# External IP address for peer discovery (required on VPS/cloud servers)
# If not set, Nethermind auto-detects via icanhazip.com (may fail behind NAT)
# Set this to your server's public IP address for reliable peer connections
NETHERMIND_EXTERNAL_IP=

# Enable UPnP for automatic port forwarding (useful for home routers)
# Not recommended for VPS/cloud - use firewall rules instead
NETHERMIND_ENABLE_UPNP=false

# =============================================================================
# ALERTING CONFIGURATION
# =============================================================================

# Slack Webhook URL (required for alerts)
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3000

# Grafana User Sign-up Settings
# Enable user registration (default: false)
GRAFANA_ALLOW_SIGN_UP=false
# Restrict sign-ups to a specific email domain (e.g., "aboutcircles.com")
# Leave empty to allow any domain (only works if sign-up is enabled)
GRAFANA_ALLOWED_EMAIL_DOMAIN=
# Default role for new users: Viewer, Editor, or Admin
GRAFANA_DEFAULT_ROLE=Viewer
# Allow anonymous access to dashboards (read-only, no login required)
GRAFANA_ANONYMOUS_ACCESS=false

# =============================================================================
# ESCALATION OPTIONS (uncomment and configure as needed)
# =============================================================================

# Telegram - for mobile push notifications
# 1. Create bot via @BotFather on Telegram
# 2. Get chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Edit alertmanager.yml: set chat_id integer and uncomment telegram-critical route
TELEGRAM_BOT_TOKEN=your-bot-token-here

# PagerDuty - for on-call rotation and phone calls
# 1. Create PagerDuty service with "Events API v2" integration
# 2. Copy the Integration Key (routing key)
# 3. Uncomment pagerduty-critical route in alertmanager.yml
# PAGERDUTY_SERVICE_KEY=your-integration-key-here

# Webhook - for custom integrations (Pushover, ntfy.sh, Twilio, etc.)
# See alertmanager.yml comments for setup instructions
# WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
# WEBHOOK_TOKEN=optional-auth-token

# =============================================================================
# PRICING / COINGECKO CONFIGURATION
# =============================================================================
# CoinGecko API key for fetching GNO/USD price (used to derive CRC/USD)
# Get a free key at: https://www.coingecko.com/api/pricing
# Free tier: 30 requests/min, 10,000 requests/month
COINGECKO_API_KEY=your-coingecko-api-key-here

# Fallback CRC price in USD (used if CoinGecko API is unavailable)
# This is a manual estimate - update based on GNO offer price
PRICING_FALLBACK_CRC_PRICE_USD=0.01

# Price cache expiry in minutes (default: 5)
# Increase to reduce API calls, decrease for more real-time prices
PRICING_CACHE_EXPIRY_MINUTES=5