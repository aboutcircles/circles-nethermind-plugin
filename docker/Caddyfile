# Circles RPC Service (JSON-RPC + WebSocket)
{$CIRCLES_RPC_DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint
    handle /ws/subscribe {
        reverse_proxy rpc:8080
    }

    # All RPC requests
    handle {
        reverse_proxy rpc:8080
    }
}

# Chain RPC (Nethermind JSON-RPC)
{$CHAIN_RPC_DOMAIN:localhost} {
    encode zstd gzip

    handle {
        reverse_proxy nethermind-gnosis:8545
    }
}

# Pathfinder Service
{$PATHFINDER_DOMAIN:localhost} {
    encode zstd gzip

    handle {
        reverse_proxy pathfinder:8080
    }
}
