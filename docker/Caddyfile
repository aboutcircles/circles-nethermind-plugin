{
  email tobias.leinss@gnosis.io
  log {
    format json {
      time_format iso8601
    }
  }
  servers {
    metrics
  }
  admin :2019
}

# Main domain (HTTPS)
{$DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint
    handle /ws/subscribe {
        reverse_proxy rpc:8080 {
            rewrite /ws/subscribe
        }
    }

    # Dashboard HTML and JSON-RPC API under /chain-rpc
    handle_path /chain-rpc/* {
        reverse_proxy nethermind-gnosis:8545
    }

    handle_path /chain-rpc {
        reverse_proxy nethermind-gnosis:8545
    }

    # Pathfinder - forwards /pathfinder/X to pathfinder:8080/X
    handle_path /pathfinder/* {
        reverse_proxy pathfinder:8080
    }

    handle_path /pathfinder {
        reverse_proxy pathfinder:8080
    }

    # Profile Service - forwards /profiles/X to profile-service:3000/X
    handle_path /profiles/* {
        reverse_proxy profile-service:3000
    }

    handle_path /profiles {
        reverse_proxy profile-service:3000
    }

    # Grafana dashboard - preserve /grafana path for subpath serving
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    handle /grafana {
        reverse_proxy grafana:3000
    }

    # Default: RPC service
    handle {
        reverse_proxy rpc:8080
    }
}
