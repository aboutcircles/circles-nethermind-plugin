{
  email tobias.leinss@gnosis.io
}

{$DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint
    handle /ws/subscribe {
        reverse_proxy rpc:8080 {
            rewrite /ws/subscribe
        }
    }

    # Nethermind JSON-RPC
    handle /nethermind/* {
        uri strip_prefix /nethermind
        reverse_proxy nethermind-gnosis:8545
    }

    handle /nethermind {
        reverse_proxy nethermind-gnosis:8545
    }

    # Pathfinder
    handle /pathfinder/* {
        uri strip_prefix /pathfinder
        reverse_proxy pathfinder:8080
    }

    handle /pathfinder {
        reverse_proxy pathfinder:8080
    }

    # Default: RPC service
    handle {
        reverse_proxy rpc:8080
    }
}
