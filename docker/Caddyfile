# Temporary domain - replace with production domain when ready

{$DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint (root level)
    # Caddy automatically handles WebSocket upgrade headers
    handle /ws/subscribe {
        reverse_proxy rpc:8080
    }

    # Root path - RPC service (primary endpoint for JSON-RPC POST requests)
    handle / {
        reverse_proxy rpc:8080
    }

    # RPC explicit path - includes WebSocket at /rpc/ws/subscribe
    handle /rpc/ws/subscribe {
        reverse_proxy rpc:8080 {
            # Preserve the /ws/subscribe path for the upstream
            rewrite /ws/subscribe
        }
    }

    handle /rpc/* {
        uri strip_prefix /rpc
        reverse_proxy rpc:8080
    }

    handle /rpc {
        reverse_proxy rpc:8080
    }

    # Nethermind JSON-RPC
    handle /nethermind/* {
        uri strip_prefix /nethermind
        reverse_proxy nethermind-gnosis:8545
    }

    handle /nethermind {
        reverse_proxy nethermind-gnosis:8545
    }

    # Profile Service
    handle /profile-service/* {
        uri strip_prefix /profile-service
        reverse_proxy profile-service:3000
    }

    handle /profile-service {
        reverse_proxy profile-service:3000
    }

    # Pathfinder
    handle /pathfinder/* {
        uri strip_prefix /pathfinder
        reverse_proxy pathfinder:8080
    }

    handle /pathfinder {
        reverse_proxy pathfinder:8080
    }

    # Fallback - send to RPC
    handle {
        reverse_proxy rpc:8080
    }
}
