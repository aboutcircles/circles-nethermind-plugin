{
  email tobias.leinss@gnosis.io
}

{$DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint
    handle /ws/subscribe {
        reverse_proxy rpc:8080 {
            rewrite /ws/subscribe
        }
    }

    # Nethermind JSON-RPC (with dashboard)
    # Static assets for dashboard (relative paths in HTML)
    @nethermind_assets path /css/* /js/* /logos/* /favicon.webp /nethermind.svg
    handle @nethermind_assets {
        reverse_proxy nethermind-gnosis:8545
    }

    handle_path /chain-rpc/* {
        reverse_proxy nethermind-gnosis:8545
    }

    handle_path /chain-rpc {
        reverse_proxy nethermind-gnosis:8545
    }

    # Pathfinder
    handle_path /pathfinder/* {
        reverse_proxy pathfinder:8080
    }

    handle_path /pathfinder {
        reverse_proxy pathfinder:8080
    }

    # Default: RPC service
    handle {
        reverse_proxy rpc:8080
    }
}
