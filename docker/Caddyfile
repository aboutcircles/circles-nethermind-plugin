  email tobias.leinss@gnosis.io
}

# Nethermind dashboard on IP (HTTP only)
{$SERVER_IP:localhost}:80 {
    reverse_proxy nethermind-gnosis:8545
}

# Main domain (HTTPS)
{$DOMAIN:localhost} {
    encode zstd gzip

    # WebSocket subscription endpoint
    handle /ws/subscribe {
        reverse_proxy rpc:8080 {
            rewrite /ws/subscribe
        }
    }

    # Nethermind dashboard assets and API (root level for JS compatibility)
    # These are requested by the dashboard JS at root level
    @nethermind_root path /data/events /css/* /js/* /logos/* /*.woff2 /favicon.webp /nethermind.svg
    handle @nethermind_root {
        reverse_proxy nethermind-gnosis:8545
    }

    # Dashboard HTML and JSON-RPC API under /chain-rpc
    handle_path /chain-rpc/* {
        reverse_proxy nethermind-gnosis:8545
    }

    handle_path /chain-rpc {
        reverse_proxy nethermind-gnosis:8545
    }

    # Pathfinder
    handle_path /pathfinder/* {
        reverse_proxy pathfinder:8080
    }

    handle_path /pathfinder {
        reverse_proxy pathfinder:8080
    }

    handle_path /profiles {
        reverse_proxy profile-service:3000
    }

    # Default: RPC service
    handle {
        reverse_proxy rpc:8080
    }
}
