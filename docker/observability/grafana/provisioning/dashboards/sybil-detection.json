      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "circles_suspicious_accounts", "refId": "A" }],
      "title": "Suspicious Accounts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentage of all accounts flagged as suspicious. Formula: suspicious / (suspicious + organic) × 100. High ratios may indicate sybil attacks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 }] },
          "unit": "percent",
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(circles_suspicious_accounts / (circles_suspicious_accounts + circles_organic_accounts)) * 100", "refId": "A" }],
      "title": "Suspicious Ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Registered accounts without profile metadata (no CID in UpdateMetadataDigest). Real users typically create profiles; bots often don't.",
