<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
  <!-- NuGet Package Metadata -->
  <Version>0.0.1</Version>
  <Authors>Gnosis Service GmbH</Authors>
  <Copyright>Gnosis Service GmbH</Copyright>
  <Product>Circles</Product>
  <PackageId>Gnosis.Circles.Nethermind.Plugin.Common</PackageId>
  <Description>Common utilities and interfaces for Circles indexing</Description>
  <PackageTags>circles;blockchain;indexing</PackageTags>
  <RepositoryUrl>https://github.com/aboutcircles/circles-nethermind-plugin</RepositoryUrl>
  <PackageProjectUrl>https://github.com/aboutcircles/circles-nethermind-plugin</PackageProjectUrl>
  <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql" Version="9.0.3" />
    <PackageReference Include="Nethereum.Util" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Nethermind.ReferenceAssemblies" Version="1\.35\.8" />
    <PackageReference Include="Nethermind.Numerics.Int256" Version="1.3.6" />
  </ItemGroup>

</Project>