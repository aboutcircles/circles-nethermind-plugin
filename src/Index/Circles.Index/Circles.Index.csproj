    </ProjectReference>
    <ProjectReference Include="..\..\Common\Circles.Common\Circles.Common.csproj">
      <PrivateAssets>all</PrivateAssets>
    </ProjectReference>
    <ProjectReference
      Include="..\Circles.Index.DatabaseSchemaProvider\Circles.Index.DatabaseSchemaProvider.csproj">
      <PrivateAssets>all</PrivateAssets>
