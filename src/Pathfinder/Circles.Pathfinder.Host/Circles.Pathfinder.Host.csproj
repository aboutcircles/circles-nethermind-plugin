<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <InvariantGlobalization>true</InvariantGlobalization>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <AssemblyVersion>1.25.0</AssemblyVersion>
        <FileVersion>1.25.0</FileVersion>

        <!-- RuntimeIdentifier can be set via CLI: dotnet publish -r linux-x64 or linux-arm64 -->
        <!-- For local development (dotnet run), don't set a default RuntimeIdentifier -->
        <RuntimeIdentifiers>linux-x64;linux-arm64</RuntimeIdentifiers>
        <SelfContained>true</SelfContained>
        <Configuration>Release</Configuration>
        <PublishSingleFile>true</PublishSingleFile>
        <PublishTrimmed>false</PublishTrimmed>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Circles.Pathfinder\Circles.Pathfinder.csproj" />
        <PackageReference Include="Gnosis.Circles.Nethermind.Plugin" Version="0.0.7" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.11.1" />
      <PackageReference Include="prometheus-net" Version="8.2.1" />
      <PackageReference Include="prometheus-net.AspNetCore" Version="8.2.1" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Nethermind.Numerics.Int256" Version="1.3.6" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="LogDb\0_applied_migrations.sql" />
      <None Remove="LogDb\1_request_and_response.sql" />
      <None Remove="LogDb\2_request_block_no.sql" />
      <None Remove="LogDb\3_index_numeric_values.sql" />
    </ItemGroup>

</Project>
