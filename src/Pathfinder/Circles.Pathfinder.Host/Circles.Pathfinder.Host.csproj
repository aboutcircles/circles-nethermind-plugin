<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <InvariantGlobalization>true</InvariantGlobalization>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <AssemblyVersion>1.25.1</AssemblyVersion>
        <FileVersion>1.25.1</FileVersion>

        <!-- RuntimeIdentifier can be set via CLI: dotnet publish -r linux-x64 or linux-arm64 -->
        <!-- For local development (dotnet run), don't set a default RuntimeIdentifier -->
        <RuntimeIdentifiers>linux-x64;linux-arm64</RuntimeIdentifiers>
        <SelfContained>true</SelfContained>
        <Configuration>Release</Configuration>
        <PublishSingleFile>true</PublishSingleFile>
        <PublishTrimmed>false</PublishTrimmed>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);CS1591</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
            <_Parameter1>Circles.Pathfinder.Tests</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Circles.Pathfinder\Circles.Pathfinder.csproj" />
        <ProjectReference Include="..\..\Common\Circles.Common\Circles.Common.csproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.OpenApi" Version="2.0.0" />
      <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.0" />
      <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.0" />
      <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.15.0" />
      <PackageReference Include="Npgsql.OpenTelemetry" Version="9.0.3" />
      <PackageReference Include="prometheus-net" Version="8.2.1" />
      <PackageReference Include="prometheus-net.AspNetCore" Version="8.2.1" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Nethermind.Numerics.Int256" Version="1.3.6" />
    </ItemGroup>

    <ItemGroup>
      <!-- OpenAPI documentation -->
      <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.7" />
      <PackageReference Include="Scalar.AspNetCore" Version="2.4.18" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="LogDb\0_applied_migrations.sql" />
      <None Remove="LogDb\1_request_and_response.sql" />
      <None Remove="LogDb\2_request_block_no.sql" />
      <None Remove="LogDb\3_index_numeric_values.sql" />
    </ItemGroup>

</Project>
