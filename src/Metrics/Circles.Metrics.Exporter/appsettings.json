{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Circles.Metrics.Exporter": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CirclesDb": "Host=localhost;Database=postgres;Username=postgres;Password=postgres"
  },
  "RepScore": {
    "GroupId": "score_group",
    "CollectionIntervalSeconds": 120,
    "HighScoreThreshold": 70,
    "ScoreDropThreshold": 20
  },
  "Deployment": {
    "Environments": {
      "staging2": "https://staging.circlesubi.network",
      "staging": "https://staging.aboutcircles.com",
      "prod": "https://rpc.aboutcircles.com"
    }
  },
  "Metrics": {
    "CollectionIntervalSeconds": 120,
    "LiquidityCollectionIntervalSeconds": 360,
    "TrustCollectionIntervalSeconds": 300,
    "DeploymentCollectionIntervalSeconds": 300,
    "DrainDetection": {
      "ZScoreCriticalThreshold": -4.0,
      "ZScoreWarningThreshold": -3.0,
      "MinBalancePercentage": 10.0,
      "MinAbsoluteAmountCrc": 100,
      "RateAccelerationFactor": 3.0
    },
    "SybilDetection": {
      "MinUniqueRecipients": 10,
      "MinTotalWithdrawnCrc": 500,
      "MaxAvgWithdrawalCrc": 50,
      "RecipientMultiplier": 3.0
    }
  }
}
