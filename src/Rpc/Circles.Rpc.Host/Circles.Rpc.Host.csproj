<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <AssemblyVersion>1.25.0</AssemblyVersion>
    <FileVersion>1.25.0</FileVersion>
    <!-- RuntimeIdentifier can be set via CLI: dotnet publish -r linux-x64 or linux-arm64 -->
    <!-- For local development (dotnet run), don't set a default RuntimeIdentifier -->
    <RuntimeIdentifiers>linux-x64;linux-arm64</RuntimeIdentifiers>
    <UseCurrentRuntimeIdentifier>true</UseCurrentRuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>


  <ItemGroup>
    <PackageReference Include="Gnosis.Circles.Nethermind.Plugin" Version="0.0.7" />
    <PackageReference Include="Gnosis.Circles.Nethermind.Plugin.Common" Version="0.0.1" />
    <PackageReference Include="Gnosis.Circles.Nethermind.Plugin.Query" Version="0.0.1" />
    <PackageReference Include="Gnosis.Circles.Pathfinder" Version="0.0.1" />

    <PackageReference Include="Nethereum.Util" Version="5.0.0" />
    <PackageReference Include="Nethermind.Numerics.Int256" Version="1.3.6" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.11.1" />
    <PackageReference Include="prometheus-net" Version="8.2.1" />
    <PackageReference Include="prometheus-net.AspNetCore" Version="8.2.1" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="9.0.4" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="9.0.4" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Autofac" Version="8.4.0" />
    <PackageReference Include="Npgsql" Version="9.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Index\Circles.Index.DatabaseSchemaProvider\Circles.Index.DatabaseSchemaProvider.csproj">
      <Aliases>LocalSchemas</Aliases>
    </ProjectReference>
  </ItemGroup>


</Project>