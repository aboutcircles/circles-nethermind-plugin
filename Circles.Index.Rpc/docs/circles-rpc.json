  "components": {
    "schemas": {
      "Address": {
        "type": "string",
        "description": "Ethereum address (0x-prefixed, 40 hex characters)",
        "pattern": "^0x[a-fA-F0-9]{40}$",
        "example": "0xde374ece6fa50e781e81aac78e811b33d16912c7"
      },
      "UInt256": {
        "type": "string",
        "description": "256-bit unsigned integer as decimal string",
        "example": "1000000000000000000"
      },
      "CirclesEvent": {
        "type": "object",
        "description": "A Circles protocol event",
        "properties": {
          "event": {
            "type": "string",
            "description": "The event name (e.g., CrcV1_Transfer)"
          },
          "values": {
            "type": "object",
            "description": "Event-specific data fields"
          }
        },
        "required": [
          "event",
          "values"
        ]
      },
      "CirclesTokenBalance": {
        "type": "object",
        "description": "Token balance information",
        "properties": {
          "tokenAddress": {
            "type": "string"
          },
          "tokenId": {
            "type": "string"
          },
          "tokenOwner": {
            "type": "string"
          },
          "tokenType": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "attoCircles": {
            "type": "string"
          },
          "circles": {
            "type": "number"
          },
          "staticAttoCircles": {
            "type": "string"
          },
          "staticCircles": {
            "type": "number"
          },
          "attoCrc": {
            "type": "string"
          },
          "crc": {
            "type": "number"
          },
          "isErc20": {
            "type": "boolean"
          },
          "isErc1155": {
            "type": "boolean"
          },
          "isWrapped": {
            "type": "boolean"
          },
          "isInflationary": {
            "type": "boolean"
          },
          "isGroup": {
            "type": "boolean"
          }
        }
      },
      "CirclesTrustRelations": {
        "type": "object",
        "description": "Trust relationships for an address",
        "properties": {
          "user": {
            "ref": "#/components/schemas/Address"
          },
          "trusts": {
            "type": "array",
            "items": {
              "ref": "#/components/schemas/CirclesTrustRelation"
            }
          },
          "trustedBy": {
            "type": "array",
            "items": {
              "ref": "#/components/schemas/CirclesTrustRelation"
            }
          }
        }
      },
      "CirclesTrustRelation": {
        "type": "object",
        "properties": {
          "user": {
            "ref": "#/components/schemas/Address"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "SelectDto": {
        "type": "object",
        "description": "Database query parameters",
        "properties": {
          "namespace": {
            "type": "string",
            "description": "Table namespace (e.g., CrcV1, CrcV2)"
          },
          "table": {
            "type": "string",
            "description": "Table name"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Columns to select"
          },
          "filter": {
            "type": "array",
            "description": "Filter conditions"
          },
          "order": {
            "type": "array",
            "description": "Order by conditions"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum results"
          }
        }
      },
      "FilterPredicateDto": {
        "type": "object",
        "description": "Filter predicate for queries",
        "properties": {
          "column": {
            "type": "string"
          },
          "filterType": {
            "type": "string",
            "enum": [
              "Equals",
              "NotEquals",
              "GreaterThan",
              "GreaterThanOrEquals",
              "LessThan",
              "LessThanOrEquals",
              "Like",
              "NotLike",
              "In",
              "NotIn"
            ]
          },
          "value": {}
        }
      },
      "DatabaseQueryResult": {
        "type": "object",
        "properties": {
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array"
            }
          }
        }
      },
      "Profile": {
        "type": "object",
        "description": "User profile information",
        "properties": {
          "address": {
            "type": "string"
          },
          "CID": {
            "type": "string",
            "nullable": true
          },
          "lastUpdatedAt": {
            "type": "integer",
            "nullable": true
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "registeredName": {
            "type": "string",
            "nullable": true
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          },
          "previewImageUrl": {
            "type": "string",
            "nullable": true
          },
          "geoLocation": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "nullable": true
          },
          "longitude": {
            "type": "number",
            "nullable": true
          },
          "latitude": {
            "type": "number",
            "nullable": true
