{
  "openrpc": "1.2.6",
  "info": {
    "title": "Circles Protocol RPC API",
    "description": "JSON-RPC API for interacting with the Circles protocol indexer and blockchain data",
    "version": "1.0.0",
    "contact": {
      "name": "Circles UBI",
      "url": "https://aboutcircles.com"
    },
    "license": {
      "name": "AGPL-3.0",
      "url": "https://www.gnu.org/licenses/agpl-3.0.html"
    }
  },
  "servers": [
    {
      "name": "Cricles Gnosis Mainnet RPC",
      "url": "https://rpc.aboutcircles.com",
      "summary": "Production Circles RPC endpoint",
      "description": "Main production endpoint for Circles"
    },
    {
      "name": "Circles Staging RPC",
      "url": "https://rpc.circlesubi.network",
      "summary": "Staging Circles RPC endpoint",
      "description": "Use this for local development and testing"
    }
  ],
  "methods": [
    {
      "name": "circles_events",
      "description": "Returns all events affecting the specified account since block N",
      "summary": "events",
      "tags": [
        {
          "name": "Circles v1"
        }
      ],
      "params": [
        {
          "name": "address",
          "description": "The Ethereum address to query",
          "required": true,
          "schema": {
            "ref": "#/components/schemas/Address"
          },
          "default": null
        },
        {
          "name": "fromBlock",
          "description": "Starting block number (inclusive)",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          },
          "default": null
        },
        {
          "name": "toBlock",
          "description": "Ending block number (inclusive)",
          "required": false,
          "schema": {
            "type": "integer",
            "format": "int64"
          },
          "default": null
        },
        {
          "name": "eventTypes",
          "description": "Array of event types to filter",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default": null
        },
        {
          "name": "filters",
          "description": "Additional filter conditions",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "ref": "#/components/schemas/FilterPredicateDto"
            }
          },
          "default": null
        },
        {
          "name": "sortAscending",
          "description": "Sort results in ascending order",
          "required": false,
          "schema": {
            "type": "boolean"
          },
          "default": false
        }
      ],
      "result": {
        "name": "result",
        "description": "The result of the operation",
        "schema": {
          "type": "string"
        }
      }
    },
