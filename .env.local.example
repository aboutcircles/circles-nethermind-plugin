# Local Development Environment Configuration
# This file is for running services locally with dotnet run (NOT for Docker Compose)
# For Docker Compose configuration, see docker/.env.example
#
# Usage:
#   cp .env.local.example .env.local
#   source .env.local
#   ./scripts/run-pathfinder.sh

# Build Configuration
BUILD_CONFIGURATION=Debug

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
PATHFINDER_PORT=8080
RPC_PORT=8081

POSTGRES_CONNECTION_STRING="Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=postgres"
POSTGRES_READONLY_CONNECTION_STRING="Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=postgres"

# PostgreSQL credentials (for run-index.sh)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Circles Configuration
NETHERMIND_RPC_URL=http://localhost:8545
BALANCE_MODE=live

# Circles Test Wallet (used by trigger-circles-tx and subscription tests)
# Copy the 12/24-word circles.garden key phrase you want to use for local testing
CIRCLES_SEED_PHRASE=""

# Cache Service Configuration
# Set CACHE_SERVICE_URL to enable cache service integration
# Set USE_CACHE_SERVICE=true to use cache for balance/avatar queries
# Set USE_CACHE_SERVICE=false to use traditional DB + Nethermind queries (for performance comparison)
CACHE_SERVICE_URL=http://localhost:3001
USE_CACHE_SERVICE=false

# Logging
Logging__LogLevel__Default=Information

# NuGet Configuration (for publishing packages)
NUGET_API_KEY=your-nuget-api-key-here
NUGET_SOURCE=https://api.nuget.org/v3/index.json

# Test Configuration
TEST_VERBOSITY=normal